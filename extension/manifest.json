{
  "manifest_version": 3,
  "name": "Watchwall420",
  "version": "0.1.0",
  "description": "Assistant for watchwall420.web.app: allows fetching of logs.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://pooembed.eu/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Watchwall420",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
